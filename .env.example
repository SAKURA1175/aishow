# ╔══════════════════════════════════════════════════════════════════╗
# ║              Study AI — Environment Configuration               ║
# ║   Copy this file to .env and fill in your values               ║
# ║   cp .env.example .env                                          ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Port Configuration ───────────────────────────────────────────
# Main application port (access Study AI at http://localhost:8090)
AISHOW_BACKEND_PORT=8090
# Open-WebUI port (optional model playground)
AISHOW_OPEN_WEBUI_PORT=3001
# SearXNG port (private web search engine for AI)
AISHOW_SEARXNG_PORT=8081

# ─── Database (MySQL 8.0+) ────────────────────────────────────────
# If running MySQL locally (not in Docker), keep host.docker.internal
# If using a remote MySQL, replace with your server IP/hostname
AISHOW_JDBC_DRIVER=com.mysql.cj.jdbc.Driver
AISHOW_JDBC_URL=jdbc:mysql://host.docker.internal:3306/study_ai?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
AISHOW_JDBC_USERNAME=root
AISHOW_JDBC_PASSWORD=your_mysql_password

# ─── Cache (Redis 6+) ─────────────────────────────────────────────
# Redis is used for session config hot-reload and rate limiting
AISHOW_REDIS_HOST=host.docker.internal
AISHOW_REDIS_PORT=6379

# ─── AI Chat Model ────────────────────────────────────────────────
# Supports any OpenAI-compatible API endpoint:
#   Local:  LM Studio  → http://host.docker.internal:1234
#   Local:  Ollama     → http://host.docker.internal:11434/v1
#   Cloud:  OpenAI     → https://api.openai.com/v1
#   Cloud:  DeepSeek   → https://api.deepseek.com/v1
#   Cloud:  SiliconFlow→ https://api.siliconflow.cn/v1
#
# Examples:
#   AISHOW_AI_MODEL=gemma-4-e4b-it          (Local, LM Studio)
#   AISHOW_AI_MODEL=deepseek-r1             (Local, LM Studio)
#   AISHOW_AI_MODEL=gpt-4o                  (OpenAI cloud)
#   AISHOW_AI_MODEL=deepseek-chat           (DeepSeek cloud)
AISHOW_AI_MODEL=gemma-4-e4b-it
AISHOW_AI_API_URL=http://host.docker.internal:1234
AISHOW_AI_API_KEY=lm-studio
# Request timeouts (milliseconds) — increase for slow local models
AISHOW_AI_API_CONNECT_TIMEOUT_MS=2000
AISHOW_AI_API_READ_TIMEOUT_MS=120000

# ─── Embedding Model (for RAG Knowledge Base) ────────────────────
# Used to vectorize uploaded documents for semantic search.
# Set AISHOW_AI_EMBEDDING_ENABLED=false to disable RAG completely.
#
# Recommended embedding models:
#   text-embedding-bge-m3       (multilingual, best for Chinese)
#   text-embedding-3-small      (OpenAI, requires API key)
#   nomic-embed-text            (Ollama)
AISHOW_AI_EMBEDDING_ENABLED=true
AISHOW_AI_EMBEDDING_MODEL=text-embedding-bge-m3
AISHOW_AI_EMBEDDING_API_URL=http://host.docker.internal:1234
AISHOW_AI_EMBEDDING_API_KEY=lm-studio

# ─── Vector Database (ChromaDB) ──────────────────────────────────
# ChromaDB stores document embeddings for RAG retrieval.
# Start ChromaDB: docker run -p 8000:8000 chromadb/chroma
AISHOW_AI_CHROMA_BASE_URL=http://host.docker.internal:8000/api/v2

# ─── Open-WebUI Integration (Optional) ───────────────────────────
# Open-WebUI is bundled for model management. Same API endpoint
# as AISHOW_AI_API_URL but with /v1 suffix.
AISHOW_OPENAI_API_BASE_URL=http://host.docker.internal:1234/v1
AISHOW_OPENAI_API_KEY=sk-lmstudio
AISHOW_OPEN_WEBUI_TASK_MODEL=gemma-4-e4b-it

# ─── Security ─────────────────────────────────────────────────────
# Change this to a random string in production!
AISHOW_SEARXNG_SECRET=change-me-to-a-random-string
